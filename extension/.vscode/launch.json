{
  "version": "0.2.0",
  "configurations": [
    {
      // Default: no preLaunchTask. `out/` is already compiled and the extension
      // has ZERO third-party runtime deps (only node builtins + the vscode API),
      // so this runs without npm install. Fewer things to fail on a first try.
      "name": "codevis: demo_project",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "${workspaceFolder}/../demo_project"
      ],
      "outFiles": ["${workspaceFolder}/out/**/*.js"]
    },
    {
      "name": "codevis: pick a folder",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "outFiles": ["${workspaceFolder}/out/**/*.js"]
    },
    {
      // Use this one if you edit the TypeScript. Needs `npm install` first.
      "name": "codevis: recompile + run",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "${workspaceFolder}/../demo_project"
      ],
      "outFiles": ["${workspaceFolder}/out/**/*.js"],
      "preLaunchTask": "npm: compile"
    }
  ]
}
